# crew — environment variables
# Copy this file to .env, fill in real values, then `chmod 600 .env`.
#
# Two ways to provide secrets — pick ONE:
#
#   (A) Infisical (recommended for production)
#       Set the four INFISICAL_* values below. crew pulls
#       ANTHROPIC_API_KEY / TELEGRAM_* / NVD_API_KEY at startup
#       from your Infisical project. Leave the secret values commented out.
#
#   (B) Plain env (simplest for local dev)
#       Leave INFISICAL_* unset and uncomment + fill the secret values directly.
#
# Anything you set in this .env always wins over Infisical (so local overrides work).

# ============================================================
# (A) Infisical — pulls secrets at startup
# ============================================================
# Cloud region: https://eu.infisical.com (EU) or https://app.infisical.com (US)
export INFISICAL_HOST=https://eu.infisical.com

# Universal Auth — create a Machine Identity in your Infisical project
# (Project → Access Control → Machine Identities → Create), give it
# read-only access to the secrets path, then copy the client ID/secret here.
# https://infisical.com/docs/documentation/platform/identities/universal-auth
export INFISICAL_CLIENT_ID=
export INFISICAL_CLIENT_SECRET=

# Project to pull from. Find the ID in Project Settings → "Project ID".
export INFISICAL_PROJECT_ID=

# Environment slug (dev / staging / prod) and secret path.
export INFISICAL_ENV=prod
export INFISICAL_SECRET_PATH=/crew

# ============================================================
# (B) Plain env — uncomment if NOT using Infisical
# ============================================================
# Anthropic API key — https://console.anthropic.com
# Set a hard monthly spend cap in the Anthropic console.
# export ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token — get from @BotFather on Telegram
# export TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# Your personal Telegram chat ID — get by DMing your bot then visiting
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Personal DM: positive integer (e.g. 987654321)
# Supergroup: negative, prefixed with -100 (e.g. -1002451541246)
# export TELEGRAM_CHAT_ID=987654321

# Optional: post into a specific topic of a forum-enabled supergroup.
# Get from `message_thread_id` in the /getUpdates response.
# export TELEGRAM_THREAD_ID=8884

# NVD API key — https://nvd.nist.gov/developers/request-an-api-key
# Optional. Without it, NVD rate-limits to ~5 req / 30 sec (fine for daily use).
# export NVD_API_KEY=

# ============================================================
# Runtime paths & model — safe to keep here (not secrets)
# ============================================================
# SQLite state DB (signal dedup across runs)
export CREW_DB_PATH=/opt/crew/state.db

# File storing last Telegram update_id (so we don't re-process replies)
export CREW_TG_STATE=/opt/crew/last_update.txt

# Claude model. Check docs.claude.com for current names.
# export CREW_MODEL=claude-opus-4-5
